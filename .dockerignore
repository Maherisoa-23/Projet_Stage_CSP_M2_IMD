# Exclus du contexte de build Docker (image livrable designer uniquement).
# Objectif : contexte de build leger et rapide, ne pas embarquer les 3.9 GB
# de DB d'exploration ni l'historique de developpement.

.git/
.gitignore

# Environnements Python locaux (l'image installe ses propres deps)
venv/
**/__pycache__/
*.pyc

# Bases de donnees volumineuses (exploration de corpus, hors perimetre
# du livrable designer ; integrees au runtime via volume + script
# integrate_corpus, jamais dans l'image).
# ATTENTION : contrairement a .gitignore, un motif *.db dans .dockerignore
# ne matche QUE la racine du contexte. Il faut **/*.db pour exclure les
# .db niches (ex. viewer/corpus_only_for_chimiste.db, 11 Go, qui faisait
# passer le contexte de build de ~30 Mo a ~23 Go => build "fige").
**/*.db
**/*.db-journal
**/*.sqlite
**/*.sqlite3

# Exports JSONL de secours (4 Go) et fichiers temporaires
exports/
tmp/

# Donnees de jobs designer locaux (l'image part d'un /data vide)
viewer/output/

# Resultats experimentaux / cluster (volumineux, hors perimetre)
experiments/
cluster_results/
backup/

# Documentation / memoire (pas necessaire dans l'image)
doc/
implementation_csp/
*.pdf
*.tex

# Outils annexes non utilises par le designer en conteneur
pah-tools-master/
divers/
non_benzenoid_generator/
optimisation_et_test_planarite/

# Fichiers de dev
.vscode/
.idea/
*.log
_docker_poc_test/
