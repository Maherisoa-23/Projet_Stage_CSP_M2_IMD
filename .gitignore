# ===== Python =====
**/__pycache__/
*.pyc

data/

# ===== Environnement Python =====
venv/

# ===== Outils IDE / agents =====
.claude/

# ===== Bases SQLite (regenerables via viewer/build_db.py) =====
*.db
*.db-shm
*.db-wal

# ===== Logs =====
*.log

# ===== Dossiers de travail jetables =====
# Scripts temporaires et fichiers intermediaires (rebuild DB, count cluster,
# sync checks, etc.). Tout ce qui est jetable apres run.
tmp/
# Archives diverses (anciens fichiers, code deplace lors des refactors).
divers/
# Docs recuperes du commit a67f065^ (rapport de stage + notes chimie + tex).
# Volontairement hors-git : archive locale de reference.
doc from commit/

# ===== Inputs lourds des experimentations (regenerables, ~10 MB+) =====
experiments/v1/plane/
experiments/v1/experiments_bundle.zip

# ===== Sorties d'experimentations (regenerables via run_one_job) =====
experiments/**/output/
experiments/**/_runs/
experiments/**/_results/
experiments/**/_run_v2/
experiments/**/_ev2_run/
experiments/**/_ev3_run/
experiments/**/_ev3_val/

# ===== Viewer =====
# Le code dans viewer/ est tracke (731 fichiers indexes avant que cette regle
# soit ajoutee). Cette regle empeche les NOUVEAUX dossiers (viewer/output/,
# viewer/missing_export/, viewer/__pycache__/, etc.) d'etre tracks.
viewer/

# ===== doc/ : artefacts d'experimentations (PDFs, captures, .tex generes) =====
# Tout ce qu'on a genere durant les experimentations CSP/motifs est ignore.
# Seul experimentation.md (synthese) est versionne dans doc/.
# Les fichiers de doc/ pre-existants (memoire.tex, etc.) restent tracks
# normalement -- .gitignore n'affecte pas les fichiers deja indexes.
doc/captures/
doc/motifs_bord_h8.tex
doc/motifs_bord_h8.pdf
